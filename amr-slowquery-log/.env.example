# ── Azure Monitor Log Analytics ───────────────────────────────────────────────
# Data Collection Endpoint URL (from DCE resource → logsIngestion.endpoint)
DCE_ENDPOINT=https://<dce-name>.<region>-1.ingest.monitor.azure.com

# DCR immutableId (from Data Collection Rule → Overview → JSON view)
DCR_RULE_ID=dcr-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Exporter behaviour ────────────────────────────────────────────────────────
# How often to poll for new slow log entries (seconds)
POLL_INTERVAL_SECONDS=60

# Maximum number of SLOWLOG entries to fetch per poll
SLOWLOG_BATCH_SIZE=128

# Output file (JSONL — one JSON object per line)
OUTPUT_FILE=slowquery.jsonl

# State file stores the last exported entry ID to avoid duplicates across restarts
STATE_FILE=.slowquery_state.json

# ── K8s overlay deployment ───────────────────────────────────────────────────
# (DCE_ENDPOINT and DCR_RULE_ID above are shared with the exporter)
IMAGE_REPO=<your-acr-name>.azurecr.io/amr-slowquery-exporter
IMAGE_TAG=latest
UAMI_CLIENT_ID=<uami-client-id>

# ── Workbook deployment (deploy-workbook.py) ──────────────────────────────────
SUBSCRIPTION_ID=<your-subscription-id>
RESOURCE_GROUP=<your-resource-group>
WORKSPACE_NAME=<your-workspace-name>
LOCATION=<location>

# ── Local testing only (replaced by clusters-config.yaml in K8s deployment) ──
# In K8s, cluster connection params are defined in k8s/overlays/template/clusters-config.yaml.
# The variables below are only needed when running exporter.py directly (e.g. python exporter.py).
AMR_HOST=mycache.eastus.redis.azure.net
AMR_PORT=10000
AMR_CLUSTER_POLICY=enterprise
AMR_CLUSTER_NAME=my-cluster-name
AMR_SSL_VERIFY=true

# Option 1: Access key (simpler)
AMR_ACCESS_KEY=your-primary-or-secondary-access-key

# Option 2: Microsoft Entra ID — service principal
# AMR_USE_ENTRA=true
# AMR_ENTRA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AMR_ENTRA_CLIENT_SECRET=your-client-secret
# AMR_ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Option 3: Microsoft Entra ID — system-assigned managed identity
# AMR_USE_ENTRA=true
# AMR_USE_MANAGED_IDENTITY=true
